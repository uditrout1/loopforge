{
  "name": "@loopforge/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=.env --watch dist/index.js",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@loopforge/core": "workspace:*",
    "@loopforge/brain": "workspace:*",
    "@loopforge/router": "workspace:*",
    "@loopforge/skills": "workspace:*",
    "@loopforge/backlog": "workspace:*",
    "@loopforge/workflows": "workspace:*",
    "@loopforge/spec": "workspace:*",
    "@loopforge/adr": "workspace:*",
    "@loopforge/vision": "workspace:*",
    "@loopforge/graph": "workspace:*",
    "@loopforge/goals": "workspace:*",
    "@loopforge/evals": "workspace:*",
    "@loopforge/db": "workspace:*",
    "hono": "^4.4.0",
    "@hono/node-server": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*"
  }
}
