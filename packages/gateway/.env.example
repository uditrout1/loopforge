# Required for LLM routing
OPENROUTER_API_KEY=

# Optional: restrict gateway to a specific network interface
# HOST=127.0.0.1

# Optional: require API key for all requests (required when HOST != 127.0.0.1)
# LOOPFORGE_API_KEY=

# Supabase persistence — when both are set, all stores persist across restarts.
# When omitted, the gateway falls back to in-memory stores.
SUPABASE_URL=https://scjdtrbrvzfxexbapgvi.supabase.co
SUPABASE_ANON_KEY=

# Optional: comma-separated allowed CORS origins
# CORS_ORIGINS=http://localhost:3000

# Optional: allowed repo root directories (colon-separated)
# ALLOWED_REPO_ROOTS=/Users/you/Projects
