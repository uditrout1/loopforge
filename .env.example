# ─── LoopForge Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in values before running.
# Minimum required: OPENROUTER_API_KEY

# ─── Model Routing ────────────────────────────────────────────────────────────

# Cloud models via OpenRouter — required for frontier/medium/small tiers
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# On-prem / local model inference via Ollama
# Confidential and restricted projects are routed here automatically
OLLAMA_BASE_URL=http://localhost:11434

# ─── Gateway ─────────────────────────────────────────────────────────────────

PORT=18790

# 127.0.0.1 = localhost only (no API key required)
# 0.0.0.0   = network accessible (LOOPFORGE_API_KEY becomes required)
HOST=127.0.0.1

# Required when HOST=0.0.0.0 — use: openssl rand -hex 32
LOOPFORGE_API_KEY=

# Colon-separated repo paths the gateway is allowed to index
# Prevents path traversal — only paths under these roots can be connected
ALLOWED_REPO_ROOTS=

# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000

# ─── Persistence ─────────────────────────────────────────────────────────────

# Without these, LoopForge uses in-memory stores (data lost on restart)
# Get from: Supabase dashboard → project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Integrations ────────────────────────────────────────────────────────────

# GitHub webhook secret — must match the value set in your repo webhook settings
GITHUB_WEBHOOK_SECRET=

# ─── Docker (optional) ───────────────────────────────────────────────────────

# Host path mounted as /repos inside the gateway container
REPO_MOUNT_PATH=/tmp/repos
