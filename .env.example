# Model routing
OPENROUTER_API_KEY=sk-or-...
OLLAMA_BASE_URL=http://localhost:11434

# Gateway
PORT=18790
HOST=127.0.0.1            # Set to 0.0.0.0 for remote access (requires DEVOS_API_KEY)
DEVOS_API_KEY=            # Required when HOST != 127.0.0.1
ALLOWED_REPO_ROOTS=       # Colon-separated allowed repo paths (e.g. /home/user/projects:/srv/repos)
CORS_ORIGINS=             # Comma-separated allowed origins (e.g. http://localhost:3000)

# Supabase (production — replaces in-memory stores)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub integration
GITHUB_WEBHOOK_SECRET=    # For GitHub webhook verification
